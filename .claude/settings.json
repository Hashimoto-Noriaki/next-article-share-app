{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run type-check)",
      "Bash(npm run test)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr review:*)",
      "Bash(git diff:*)",
      "Bash(git status)",
      "Bash(git commit:*)",
      "Read",
      "Grep",
      "Glob"
    ],
    "deny": ["Read(.env)", "Read(.env.*)"]
  }
}
